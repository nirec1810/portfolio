---
export interface Props {
  class?: string
  direction?: 'up' | 'down' | 'left' | 'right' | 'none'
  delay?: number
  duration?: number
  distance?: string
  rootMargin?: string
}

const {
  class: className = '',
  direction = 'up',
  delay = 0,
  duration = 600,
  distance = '1.5rem',
  rootMargin = '-40px',
} = Astro.props

const directionMap: Record<string, string> = {
  up: `translateY(${distance})`,
  down: `translateY(-${distance})`,
  left: `translateX(${distance})`,
  right: `translateX(-${distance})`,
  none: 'none',
}
---

<div
  class:list={[className, 'reveal']}
  data-reveal
  style={`--reveal-transform: ${directionMap[direction]}; --reveal-delay: ${delay}ms; --reveal-duration: ${duration}ms; --reveal-root-margin: ${rootMargin}`}
>
  <slot />
</div>

<script>
const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
if (!prefersReduced) {
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('reveal-visible')
          observer.unobserve(entry.target)
        }
      })
    },
    { rootMargin: '-40px 0px' },
  )
  document.querySelectorAll('[data-reveal]').forEach((el) => observer.observe(el))
}
</script>

<style is:global>
.reveal {
  opacity: 0;
  transform: var(--reveal-transform, translateY(1.5rem));
  transition: opacity var(--reveal-duration, 600ms) cubic-bezier(0.22, 1, 0.36, 1) var(--reveal-delay, 0ms),
              transform var(--reveal-duration, 600ms) cubic-bezier(0.22, 1, 0.36, 1) var(--reveal-delay, 0ms);
  will-change: opacity, transform;
}

.reveal-visible {
  opacity: 1;
  transform: translate(0, 0);
}

@media (prefers-reduced-motion: reduce) {
  .reveal {
    opacity: 1;
    transform: none;
    transition: none;
  }
}
</style>
