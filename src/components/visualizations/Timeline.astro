---
import ScrollReveal from '../ui/ScrollReveal.astro'

export interface TimelineEvent {
  date: string
  title: string
  subtitle: string
  description?: string
  highlights?: string[]
  type: 'experience' | 'education'
}

export interface Props {
  events: TimelineEvent[]
  class?: string
}

const { events, class: className = '' } = Astro.props
---

<div class:list={[className, 'relative']} role="list" aria-label="Career timeline">
  <div class="absolute left-4 md:left-6 top-0 bottom-0 w-px bg-stone-200 dark:bg-stone-800 timeline-line" aria-hidden="true" />

  {events.map((event, idx) => {
    const isExperience = event.type === 'experience'
    return (
      <ScrollReveal direction="up" delay={idx * 80}>
        <div class="relative pl-10 md:pl-14 pb-8 last:pb-0 group" role="listitem">
          <div class="absolute left-[14px] md:left-[22px] top-1.5 w-2.5 h-2.5 rounded-full ring-4 ring-stone-50 dark:ring-[#111110] transition-transform duration-300 group-hover:scale-150 timeline-dot"
            class:list={[
              isExperience ? 'bg-amber-500' : 'bg-emerald-500',
            ]}
            aria-hidden="true"
          />

          <div class="rounded-xl border border-stone-200 bg-white p-5 transition-all duration-300 hover:border-stone-300 hover:shadow-md dark:border-stone-800 dark:bg-stone-900 dark:hover:border-stone-700 timeline-card">
            <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-2">
              <div>
                <h3 class="font-display font-semibold text-stone-900 dark:text-stone-100 text-sm md:text-base">
                  {event.title}
                </h3>
                <p class="text-xs md:text-sm font-medium"
                  class:list={[
                    isExperience ? 'text-amber-600 dark:text-amber-400' : 'text-emerald-600 dark:text-emerald-400',
                  ]}>
                  {event.subtitle}
                </p>
              </div>
              <time class="shrink-0 text-xs text-stone-400 dark:text-stone-500 font-mono">{event.date}</time>
            </div>

            {event.description && (
              <p class="text-sm text-stone-500 dark:text-stone-400 leading-relaxed">{event.description}</p>
            )}

            {event.highlights && event.highlights.length > 0 && (
              <ul class="mt-3 space-y-1.5">
                {event.highlights.map((item) => (
                  <li class="flex items-start gap-2 text-xs md:text-sm text-stone-600 dark:text-stone-300">
                    <svg class="mt-0.5 h-3.5 w-3.5 shrink-0 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
            )}
          </div>
        </div>
      </ScrollReveal>
    )
  })}
</div>

<style is:global>
.timeline-line {
  animation: timeline-grow 1.2s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  transform-origin: top center;
  transform: scaleY(0);
}

@keyframes timeline-grow {
  from { transform: scaleY(0); }
  to { transform: scaleY(1); }
}

.timeline-dot {
  transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
}

.timeline-card {
  transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.25s ease, border-color 0.25s ease;
}

.timeline-card:hover {
  transform: translateY(-2px);
}
</style>
