---
import BaseLayout from '../../layouts/BaseLayout.astro'
import ProjectCard from '../../components/ProjectCard.astro'
import ScrollReveal from '../../components/ui/ScrollReveal.astro'
import Counter from '../../components/ui/Counter.astro'
import SkillBar from '../../components/ui/SkillBar.astro'
import Timeline from '../../components/visualizations/Timeline.astro'
import { getData } from '../../lib/mock-data'
import { getDeviconClass, getDeviconColor } from '../../lib/utils'
import { t, locales, defaultLocale, type Locale } from '../../i18n/index'

export async function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }))
}

const { lang } = Astro.params as { lang: Locale }
const data = getData(lang)

const projects = data.projects
const experience = data.experience
const skills = data.skills
const aboutMe = data.aboutMe
const education = data.education
const certifications = data.certifications
const languages = data.languages

const skillCategoryKeys = [
  { key: 'languages', icon: '{ }' },
  { key: 'frontend', icon: '</>' },
  { key: 'backend', icon: '⚙' },
  { key: 'databases', icon: '◆' },
  { key: 'devops', icon: '☁' },
  { key: 'mobile', icon: '📱' },
  { key: 'tools', icon: '🔧' },
] as const

const certCategoryColors: Record<string, { border: string; bg: string; darkBorder: string; darkBg: string }> = {
  'cloud-devops': { border: 'border-sky-400', bg: 'bg-sky-50', darkBorder: 'dark:border-sky-600', darkBg: 'dark:bg-sky-950/40' },
  'backend-mobile': { border: 'border-violet-400', bg: 'bg-violet-50', darkBorder: 'dark:border-violet-600', darkBg: 'dark:bg-violet-950/40' },
  'frontend': { border: 'border-amber-400', bg: 'bg-amber-50', darkBorder: 'dark:border-amber-600', darkBg: 'dark:bg-amber-950/40' },
  'fundamentals': { border: 'border-emerald-400', bg: 'bg-emerald-50', darkBorder: 'dark:border-emerald-600', darkBg: 'dark:bg-emerald-950/40' },
  'soft-skills': { border: 'border-rose-400', bg: 'bg-rose-50', darkBorder: 'dark:border-rose-600', darkBg: 'dark:bg-rose-950/40' },
}

const proficiencyDot: Record<string, string> = {
  advanced: 'bg-amber-500',
  intermediate: 'bg-emerald-500',
  basic: 'bg-stone-400',
  beginner: 'bg-stone-300',
}

const proficiencyValue: Record<string, number> = {
  advanced: 90,
  intermediate: 65,
  basic: 35,
  beginner: 20,
}

const timelineEvents = experience.map(exp => ({
  date: `${exp.startDate?.slice(0, 7)} — ${exp.current ? t('experience.present', lang) : exp.endDate?.slice(0, 7) || ''}`,
  title: exp.role,
  subtitle: exp.company,
  description: exp.description || undefined,
  highlights: exp.highlights?.map(h => h.item),
  type: 'experience' as const,
}))

---

<BaseLayout title={aboutMe?.name || 'Home'} lang={lang}>

  <!-- Hero -->
  <section id="about" class="mb-20 scroll-mt-24 relative" aria-labelledby="about-heading">
    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 right-0 w-96 h-96 bg-amber-500/8 dark:bg-amber-400/5 rounded-full blur-3xl -translate-y-1/4 translate-x-1/4 hero-blob" data-speed="-0.12"></div>
    </div>

    <div class="relative grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-8 items-center">
      <div class="lg:col-span-3">
        <div class="flex items-center gap-5 mb-3">
          <div class="shrink-0 flex items-center justify-center w-16 h-16 lg:w-20 lg:h-20 rounded-full bg-gradient-to-br from-amber-500 to-amber-600 text-white shadow-lg shadow-amber-500/20 dark:shadow-amber-400/10">
            <span class="font-display font-extrabold text-xl lg:text-2xl tracking-tight" aria-hidden="true">NR</span>
          </div>
          <h1 id="about-heading" class="text-4xl lg:text-5xl font-display font-extrabold tracking-tight text-stone-900 dark:text-stone-50">
            {aboutMe?.name || 'Your Name'}
          </h1>
        </div>
        <div class="h-0.5 w-16 bg-gradient-to-r from-amber-500 to-amber-600 rounded-full animate-underline" aria-hidden="true"></div>
        {aboutMe?.headline && (
          <p class="mt-3 text-lg lg:text-xl text-amber-600 dark:text-amber-400 font-medium">{aboutMe.headline}</p>
        )}

        <div class="mt-5 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-stone-500 dark:text-stone-400">
          {aboutMe?.location && (
            <span class="inline-flex items-center gap-1.5">
              <svg class="h-4 w-4 text-stone-400 dark:text-stone-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              {aboutMe.location}
            </span>
          )}
          <a href="https://github.com/nirec1810" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 hover:text-amber-600 transition-colors dark:hover:text-amber-400">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
            GitHub
          </a>
          <a href="mailto:nirec1810@gmail.com" class="inline-flex items-center gap-1.5 hover:text-amber-600 transition-colors dark:hover:text-amber-400">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            {t('hero.contact', lang)}
          </a>
          <button onclick="window.print()" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-amber-600 text-white text-sm font-semibold hover:bg-amber-700 transition-colors no-print dark:bg-amber-500 dark:text-stone-900 dark:hover:bg-amber-400">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
            {t('hero.downloadCV', lang)}
          </button>
        </div>

        {aboutMe?.bio?.map((block) => (
          <p class="mt-6 leading-relaxed text-stone-600 dark:text-stone-400 max-w-prose text-base lg:text-lg">
            {block.children?.map((child) => child.text).join(' ')}
          </p>
        ))}

        <div class="mt-8 flex flex-wrap gap-8">
          <ScrollReveal delay={200}>
            <div class="text-center">
              <div class="text-3xl font-display font-bold text-amber-600 dark:text-amber-400">
                <Counter end={projects.length} suffix="+" />
              </div>
              <div class="text-xs text-stone-500 dark:text-stone-400 mt-1 font-medium">{t('stats.projects', lang)}</div>
            </div>
          </ScrollReveal>
          <ScrollReveal delay={300}>
            <div class="text-center">
              <div class="text-3xl font-display font-bold text-amber-600 dark:text-amber-400">
                <Counter end={skills.length} suffix="+" />
              </div>
              <div class="text-xs text-stone-500 dark:text-stone-400 mt-1 font-medium">{t('stats.skillsCount', lang)}</div>
            </div>
          </ScrollReveal>
          <ScrollReveal delay={400}>
            <div class="text-center">
              <div class="text-3xl font-display font-bold text-amber-600 dark:text-amber-400">
                <Counter end={certifications.length} suffix="+" />
              </div>
              <div class="text-xs text-stone-500 dark:text-stone-400 mt-1 font-medium">{t('stats.certifications', lang)}</div>
            </div>
          </ScrollReveal>
        </div>
      </div>

      <div class="lg:col-span-2 hidden lg:block">
        <ScrollReveal direction="right" delay={300}>
          <div class="relative rounded-xl border border-stone-200 dark:border-stone-800 bg-stone-100 dark:bg-stone-900 overflow-hidden shadow-lg shadow-stone-200/50 dark:shadow-black/30">
            <div class="flex items-center gap-2 px-4 py-2.5 border-b border-stone-200 dark:border-stone-800">
              <span class="w-3 h-3 rounded-full bg-stone-300 dark:bg-stone-700"></span>
              <span class="w-3 h-3 rounded-full bg-stone-300 dark:bg-stone-700"></span>
              <span class="w-3 h-3 rounded-full bg-stone-300 dark:bg-stone-700"></span>
              <span class="ml-2 text-xs text-stone-400 dark:text-stone-500 font-mono">nirec@portfolio</span>
            </div>
            <div class="p-5 font-mono text-sm leading-relaxed">
              <div class="text-stone-400 dark:text-stone-500">$ <span class="text-amber-600 dark:text-amber-400">whoami</span></div>
              <div class="mt-1 text-stone-700 dark:text-stone-300">{t('terminal.whoami', lang)}</div>
              <div class="mt-3 text-stone-400 dark:text-stone-500">$ <span class="text-amber-600 dark:text-amber-400">cat stack.txt</span></div>
              <div class="mt-1 space-y-0.5">
                <div class="text-stone-700 dark:text-stone-300">TypeScript · Next.js · C#</div>
                <div class="text-stone-700 dark:text-stone-300">ASP.NET Core · Java · Spring</div>
                <div class="text-stone-700 dark:text-stone-300">Supabase · Docker · Azure</div>
              </div>
              <div class="mt-3 text-stone-400 dark:text-stone-500">$ <span class="text-amber-600 dark:text-amber-400">echo $STATUS</span></div>
              <div class="mt-1 text-emerald-600 dark:text-emerald-400 font-medium">{t('terminal.status', lang)}</div>
              <div class="mt-3 text-stone-400 dark:text-stone-500 terminal-cursor"></div>
            </div>
          </div>
        </ScrollReveal>
      </div>
    </div>
  </section>

  <div class="section-divider mb-16" aria-hidden="true"></div>

  <!-- Experience -->
  <section id="experience" class="mb-16 scroll-mt-24" aria-labelledby="experience-heading">
    <ScrollReveal>
      <div class="mb-8">
        <h2 id="experience-heading" class="text-2xl font-display font-bold text-stone-900 dark:text-stone-100">{t('sections.experience', lang)}</h2>
        <div class="mt-2 h-0.5 w-12 bg-gradient-to-r from-amber-500 to-amber-600 rounded-full"></div>
      </div>
    </ScrollReveal>
    <Timeline events={timelineEvents} />
  </section>

  <div class="section-divider mb-16" aria-hidden="true"></div>

  <!-- Projects -->
  <section id="projects" class="mb-16 scroll-mt-24" aria-labelledby="projects-heading">
    <ScrollReveal>
      <div class="mb-8">
        <h2 id="projects-heading" class="text-2xl font-display font-bold text-stone-900 dark:text-stone-100">{t('sections.projects', lang)}</h2>
        <div class="mt-2 h-0.5 w-12 bg-gradient-to-r from-amber-500 to-amber-600 rounded-full"></div>
      </div>
    </ScrollReveal>
    <div>
      <div class="grid gap-6 sm:grid-cols-2">
        {projects.map((project, idx) => (
          <ScrollReveal delay={idx * 80}>
            <div class="project-card" data-lang={project.primaryLanguage || 'all'}>
              <ProjectCard project={project} lang={lang} />
            </div>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>

  <div class="section-divider mb-16" aria-hidden="true"></div>

  <!-- Skills -->
  <section id="skills" class="mb-16 scroll-mt-24" aria-labelledby="skills-heading">
    <ScrollReveal>
      <div class="mb-8">
        <h2 id="skills-heading" class="text-2xl font-display font-bold text-stone-900 dark:text-stone-100">{t('sections.skills', lang)}</h2>
        <div class="mt-2 h-0.5 w-12 bg-gradient-to-r from-amber-500 to-amber-600 rounded-full"></div>
      </div>
    </ScrollReveal>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {skillCategoryKeys.map(({ key, icon }, catIdx) => {
        const categorySkills = skills.filter(s => s.category === key)
        if (categorySkills.length === 0) return null
        return (
          <ScrollReveal delay={catIdx * 60}>
            <div class="skill-bento-card rounded-xl border border-stone-200 bg-white p-5 dark:border-stone-800 dark:bg-stone-900">
              <div class="flex items-center gap-2 mb-4">
                <span class="text-amber-600 dark:text-amber-400 text-sm">{icon}</span>
                <h3 class="font-display font-semibold text-stone-900 dark:text-stone-100 text-sm">{t(`skills.${key}`, lang)}</h3>
                <span class="ml-auto text-xs text-stone-400 dark:text-stone-500 font-mono">{categorySkills.length}</span>
              </div>
              <div class="flex flex-wrap gap-1.5">
                {categorySkills.map((skill) => {
                  const iconClass = getDeviconClass(skill.name)
                  const dotColor = proficiencyDot[skill.proficiency] || 'bg-stone-400'
                  return (
                    <span class="inline-flex items-center gap-1.5 rounded-lg bg-stone-50 px-2.5 py-1.5 text-xs font-medium text-stone-700 ring-1 ring-stone-200/60 hover:bg-stone-100 transition-colors dark:bg-stone-800 dark:text-stone-300 dark:ring-stone-700/60 dark:hover:bg-stone-750">
                      {iconClass ? (
                        <i class={`${iconClass} text-sm skill-bento-icon ${getDeviconColor(skill.name)}`} aria-hidden="true"></i>
                      ) : (
                        <span class={`h-1.5 w-1.5 rounded-full shrink-0 ${dotColor}`} aria-hidden="true" />
                      )}
                      {skill.name}
                    </span>
                  )
                })}
              </div>
            </div>
          </ScrollReveal>
        )
      })}
    </div>
  </section>

  <div class="section-divider mb-16" aria-hidden="true"></div>

  <!-- Education -->
  <section id="education" class="mb-16 scroll-mt-24" aria-labelledby="education-heading">
    <ScrollReveal>
      <div class="mb-8">
        <h2 id="education-heading" class="text-2xl font-display font-bold text-stone-900 dark:text-stone-100">{t('sections.education', lang)}</h2>
        <div class="mt-2 h-0.5 w-12 bg-gradient-to-r from-amber-500 to-amber-600 rounded-full"></div>
      </div>
    </ScrollReveal>
    <div class="space-y-5">
      {education.map((edu, idx) => (
        <ScrollReveal delay={idx * 100}>
          <div class="flex items-start gap-5 rounded-xl border border-stone-200 bg-white p-6 dark:border-stone-800 dark:bg-stone-900">
            <div class="shrink-0 flex items-center justify-center w-12 h-12 rounded-xl bg-gradient-to-br from-amber-500 to-amber-600 text-white shadow-md shadow-amber-500/20">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>
            </div>
            <div class="min-w-0 flex-1">
              <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
                <div>
                  <h3 class="font-display font-semibold text-stone-900 dark:text-stone-100">{edu.institution}</h3>
                  <p class="text-sm text-amber-600 dark:text-amber-400 font-medium">{edu.degree}</p>
                </div>
                <span class="shrink-0 text-xs text-stone-400 dark:text-stone-500 font-mono">
                  {edu.startDate?.slice(0, 7)} — {edu.current ? t('education.present', lang) : edu.endDate?.slice(0, 7)}
                </span>
              </div>
              {edu.description && (
                <p class="mt-2 text-sm text-stone-500 dark:text-stone-400 leading-relaxed">{edu.description}</p>
              )}
            </div>
          </div>
        </ScrollReveal>
      ))}
    </div>
  </section>

  <div class="section-divider mb-16" aria-hidden="true"></div>

  <!-- Certifications -->
  <section id="certifications" class="mb-16 scroll-mt-24" aria-labelledby="certifications-heading">
    <ScrollReveal>
      <div class="mb-8">
        <h2 id="certifications-heading" class="text-2xl font-display font-bold text-stone-900 dark:text-stone-100">{t('sections.certifications', lang)}</h2>
        <div class="mt-2 h-0.5 w-12 bg-gradient-to-r from-amber-500 to-amber-600 rounded-full"></div>
      </div>
    </ScrollReveal>

    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {certifications.map((cert, idx) => {
        const colors = certCategoryColors[cert.category] || certCategoryColors['fundamentals']
        return (
          <ScrollReveal delay={idx * 50}>
            <div class:list={[
              'rounded-xl border-l-4 border border-stone-200 bg-white p-4 transition-all duration-200 hover:shadow-md dark:border-stone-800 dark:bg-stone-900 dark:hover:shadow-stone-900/50',
              colors.border, colors.darkBorder
            ]}>
              <h3 class="text-sm font-medium text-stone-900 dark:text-stone-100 leading-snug">{cert.name}</h3>
              <div class="mt-2.5 flex items-center gap-2 text-xs">
                {cert.platform && (
                  <span class:list={['px-2 py-0.5 rounded-md font-medium ring-1', colors.bg, colors.darkBg, colors.border, colors.darkBorder]}>{cert.platform}</span>
                )}
                <span class="text-stone-400 dark:text-stone-500 font-mono">{cert.date}</span>
              </div>
            </div>
          </ScrollReveal>
        )
      })}
    </div>
  </section>

  <div class="section-divider mb-16" aria-hidden="true"></div>

  <!-- Languages -->
  <section id="languages" class="scroll-mt-24" aria-labelledby="languages-heading">
    <ScrollReveal>
      <div class="mb-8">
        <h2 id="languages-heading" class="text-2xl font-display font-bold text-stone-900 dark:text-stone-100">{t('sections.languages', lang)}</h2>
        <div class="mt-2 h-0.5 w-12 bg-gradient-to-r from-amber-500 to-amber-600 rounded-full"></div>
      </div>
    </ScrollReveal>
    <div class="grid gap-6 sm:grid-cols-2">
      {languages.map((l, idx) => {
        const prof = l.proficiency.toLowerCase()
        const value = prof.includes('nativo') || prof.includes('native') ? 100 :
                      prof.includes('avanzado') || prof.includes('advanced') || prof.includes('b2') ? 80 :
                      prof.includes('intermedio') || prof.includes('intermediate') ? 60 : 40
        return (
          <ScrollReveal delay={idx * 100}>
            <div class="rounded-xl border border-stone-200 bg-white p-6 dark:border-stone-800 dark:bg-stone-900">
              <SkillBar
                name={l.name}
                proficiency={value}
                label={l.proficiency}
                color="bg-gradient-to-r from-amber-500 to-amber-400"
              />
            </div>
          </ScrollReveal>
        )
      })}
    </div>
  </section>

</BaseLayout>
